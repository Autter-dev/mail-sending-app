# App
APP_URL=http://localhost:3000
APP_NAME=hedwig-mail
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=          # Generate with: openssl rand -base64 32

# Tracking host (recommended in production: a separate subdomain from APP_URL).
# All open pixels, click-tracking redirects (/r/), and unsubscribe links are
# served from this host. Keeping it separate from the dashboard insulates the
# dashboard's reputation from any abuse signals on tracked links.
# Leave unset locally to fall back to APP_URL.
# TRACKING_URL=https://track.yourdomain.com

# HMAC secret used to sign click-tracking payloads so the /r/ handler is not
# an open redirect. If unset, falls back to ENCRYPTION_KEY.
# TRACKING_SECRET=          # Generate with: openssl rand -hex 32

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=            # Choose a strong password

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emailtool

# Storage (MinIO for local dev, AWS S3 for production)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=emailtool
S3_FORCE_PATH_STYLE=true   # Set to true for MinIO, remove for AWS S3

# Security
ENCRYPTION_KEY=            # Generate with: openssl rand -hex 32

# Worker
WORKER_CONCURRENCY=5

# Audit log
AUDIT_LOG_RETENTION_DAYS=365      # Daily purge job deletes entries older than this. Set to 0 to disable.
AUDIT_LOG_EXPORT_MAX_ROWS=100000  # Cap for CSV exports; tighten the date range if exceeded.

# Double opt-in confirmation emails (optional fallback)
# Preferred: configure sender at Settings > General in the dashboard.
# This env var is used only as a fallback when the dashboard setting is empty.
# CONFIRMATION_FROM_EMAIL=   # e.g. noreply@yourdomain.com

# Webhooks (optional, for bounce/complaint tracking)
# RESEND_WEBHOOK_SECRET=   # From Resend dashboard

# Logging
LOG_LEVEL=info             # debug, info, warn, error, fatal

# Tracking (optional, falls back to local pino logging if not set)
# POSTHOG_API_KEY=         # Your PostHog project API key
# POSTHOG_HOST=            # e.g. https://us.i.posthog.com
